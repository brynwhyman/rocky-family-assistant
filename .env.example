# Planner
# Rocky uses your local Claude Code CLI session by default.
# Set this only if the binary is not available on PATH.
# CLAUDE_BIN=/absolute/path/to/claude

# Local server
PORT=3457

# Messaging
# Used as a fallback identity when inbound metadata does not include a sender.
WHATSAPP_SELF_JID=15555550123@s.whatsapp.net

# Optional OpenClaw integration
# Leave unset unless you want Rocky to send outbound WhatsApp replies via OpenClaw.
# OPENCLAW_BIN=openclaw

# Amazon
AMAZON_BASE_URL=https://www.amazon.com
BROWSER_PROFILE=grocery-executor

# Google Calendar (optional)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_DEFAULT_ATTENDEES=alex@example.com,casey@example.com
GOOGLE_CALENDAR_DEFAULT_DURATION_MINUTES=60
GOOGLE_CALENDAR_TIME_ZONE=America/Los_Angeles

# Gmail / Email (optional)
GOOGLE_EMAIL_ENABLED=false
# Defaults to GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET if omitted
GOOGLE_EMAIL_CLIENT_ID=
GOOGLE_EMAIL_CLIENT_SECRET=
GOOGLE_EMAIL_REFRESH_TOKEN=
GOOGLE_EMAIL_MONITORED_LABEL_IDS=INBOX
GOOGLE_EMAIL_WATCHER_INTERVAL_MS=60000
