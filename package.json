{
  "name": "rocky-family-assistant",
  "version": "0.1.0",
  "private": false,
  "description": "Local-first family assistant for groceries, calendar, and email, with explicit confirmation before order placement",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app/server.ts",
    "start": "node dist/app/server.js",
    "build": "tsc",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test -r ts-node/register test/unit/**/*.test.ts",
    "test:integration": "node --test -r ts-node/register test/integration/**/*.test.ts",
    "test:message": "ts-node scripts/test-message.ts",
    "amazon:login": "ts-node scripts/login-amazon.ts",
    "google:auth": "ts-node scripts/google-auth.ts",
    "gmail:auth": "ts-node scripts/gmail-auth.ts"
  },
  "dependencies": {
    "chrono-node": "^2.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "playwright": "^1.44.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
